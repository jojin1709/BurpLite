{
  "manifest_version": 3,
  "name": "BurpLite",
  "version": "2.0.5",
  "author": "JOJIN JOHN",
  "description": "BurpLite: Repeater, Intruder, Decoder, and Scanner in DevTools. Capture, edit, and replay HTTP requests for testing.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "devtools_page": "devtools.html",
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "BurpLite — open Intercept side panel"
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "BurpLite Interceptor"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "burplite@jojinjohn.sec",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "status": "not_collected",
        "required": false
      }
    }
  },
  "permissions": [
    "storage",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'"
  }
}
